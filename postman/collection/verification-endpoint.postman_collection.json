	"item": [
		{
			"name": "happy path",
			"item": [
				{
					"name": "hp - search / WEB / premium",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"",
									"// Removed duplicate declaration of json",
									"pm.test(\"Status code is 200\", () => {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"JSON-RPC response has expected structure\", () => {",
									"  pm.expect(json).to.have.property(\"jsonrpc\", \"2.0\");",
									"  pm.expect(json).to.have.property(\"id\");",
									"  pm.expect(json).to.have.property(\"result\");",
									"  pm.expect(json.result).to.have.property(\"data\");",
									"});",
									"",
									"const responseData = json.result?.data;",
									"",
									"pm.test(\"Layout root fields are valid\", () => {",
									"  pm.expect(responseData).to.have.property(\"id\").that.is.a(\"string\");",
									"  pm.expect(responseData).to.have.property(\"name\").that.is.a(\"string\");",
									"  pm.expect(responseData).to.have.property(\"adPositions\").that.is.an(\"array\");",
									"  pm.expect(responseData).to.have.property(\"dimensions\").that.is.an(\"object\");",
									"  pm.expect(responseData).to.have.property(\"layoutBlocks\").that.is.an(\"array\");",
									"});",
									"",
									"pm.test(\"layoutBlocks are ordered by position\", () => {",
									"  const positions = responseData.layoutBlocks.map(block => block.position);",
									"  const sorted = [...positions].sort((a, b) => a - b);",
									"  pm.expect(positions).to.eql(sorted);",
									"});",
									"",
									"pm.test(\"Each layoutBlock has required fields\", () => {",
									"  responseData.layoutBlocks.forEach((block) => {",
									"    pm.expect(block).to.have.property(\"id\").that.is.a(\"string\");",
									"    pm.expect(block).to.have.property(\"hideWhenEmpty\").that.is.a(\"boolean\");",
									"    pm.expect(block).to.have.property(\"position\").that.is.a(\"number\");",
									"    pm.expect(block).to.have.property(\"stripData\").that.is.an(\"object\");",
									"  });",
									"});",
									"",
									"pm.test(\"Each stripData has required fields and valid enums\", () => {",
									"  const displayTypes = [\"banner\", \"default\", \"hero\", \"landscape\", \"portrait\", \"static\"];",
									"  const stripTypes = [",
									"    \"heroStrip\",",
									"    \"defaultStrip\",",
									"    \"bannerStrip\",",
									"    \"genreStrip\",",
									"    \"channelStrip\",",
									"    \"liveBroadcastStrip\",",
									"    \"topItemsStrip\"",
									"  ];",
									"",
									"  responseData.layoutBlocks.forEach((block) => {",
									"    const strip = block.stripData;",
									"",
									"    pm.expect(strip).to.have.property(\"id\").that.is.a(\"string\");",
									"    pm.expect(strip).to.have.property(\"name\").that.is.a(\"string\");",
									"    pm.expect(strip).to.have.property(\"title\").that.is.a(\"string\");",
									"",
									"    if (strip.displayType !== null) {",
									"      pm.expect(displayTypes).to.include(strip.displayType);",
									"    }",
									"",
									"    if (strip.stripType !== null) {",
									"      pm.expect(stripTypes).to.include(strip.stripType);",
									"    }",
									"  });",
									"});",
									""
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"pm.variables.set(\"requestId\", \"search-web-premium\");",
									"pm.variables.set(\"userLevel\", \"premium\");"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"{{requestId}}\",\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"{{method}}\",\n  \"params\": {\n    \"pageSlug\": \"{{pageSlug}}\",\n    \"userLevel\": \"{{userLevel}}\",\n    \"deviceType\": \"{{deviceType}}\"\n  }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}{{rpcPath}}",
							"host": [
								"{{base_url}}{{rpcPath}}"
							]
						},
						"description": "This is a POST request, submitting data to an API via the request body. This request submits JSON data, and the data is reflected in the response.\n\nA successful POST request typically returns a `200 OK` or `201 Created` response code."
					},
					"response": []
				},
