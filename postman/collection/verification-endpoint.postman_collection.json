		{
			"name": "device types verification",
			"item": [
				{
					"name": "device verification- positive",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"const iterationValue = (key) => pm.iterationData.get(key) ?? pm.environment.get(key);",
									"pm.variables.set(\"requestId\", iterationValue(\"requestId\"));",
									"pm.variables.set(\"deviceType\", iterationValue(\"deviceType\"));",
									"pm.variables.set(\"userLevel\", iterationValue(\"userLevel\"));",
									"pm.variables.set(\"pageSlug\", iterationValue(\"pageSlug\"))"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"const responseData = json.result.data;",
									"",
									"pm.test(\"Status is 200\", () => {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Valid JSON-RPC response\", () => {",
									"  pm.expect(json.jsonrpc).to.eql(\"2.0\");",
									"  pm.expect(json).to.have.property(\"result\");",
									"  pm.expect(responseData).to.have.property(\"layoutBlocks\");",
									"});",
									"",
									"pm.test(\"layoutBlocks is array\", () => {",
									"  pm.expect(responseData.layoutBlocks).to.be.an(\"array\");",
									"});",
									"",
									"pm.test(\"layoutBlocks ordered by position\", () => {",
									"  const positions = responseData.layoutBlocks.map(b => b.position);",
									"  const sorted = [...positions].sort((a, b) => a - b);",
									"  pm.expect(positions).to.eql(sorted);",
									"});",
									"",
									"pm.test(\"deviceType consistency (if returned)\", () => {",
									"  const requested = pm.variables.get(\"deviceType\");",
									"  const responseDevice = responseData.dimensions.deviceType;",
									"",
									"  if (responseDevice !== null) {",
									"    pm.expect(responseDevice).to.eql(requested);",
									"  }",
									"});",
									"",
									"pm.test(\"Each layoutBlock has required fields\", () => {",
									"  responseData.layoutBlocks.forEach(block => {",
									"    pm.expect(block).to.have.property(\"id\");",
									"    pm.expect(block).to.have.property(\"position\");",
									"    pm.expect(block).to.have.property(\"stripData\");",
									"  });",
									"});"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"{{requestId}}\",\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"{{method}}\",\n  \"params\": {\n    \"pageSlug\": \"{{pageSlug}}\",\n    \"userLevel\": \"{{userLevel}}\",\n    \"deviceType\": \"{{deviceType}}\"\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}{{rpcPath}}",
							"host": [
								"{{base_url}}{{rpcPath}}"
							]
						}
					},
					"response": []
